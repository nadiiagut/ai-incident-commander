# OpenAI — required for live LLM analysis; omit to use hardcoded fallback
OPENAI_API_KEY=sk-proj-your-key
OPENAI_MODEL=gpt-4o-mini

# ClickHouse — local log analytics backend
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=incident_demo
CLICKHOUSE_TABLE=checkout_logs

# IPinfo — optional, enables geographic enrichment of client IPs
IPINFO_TOKEN=your-ipinfo-token
